{
  "name": "quran-academy-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:apply": "bash scripts/apply_schema.sh",
    "db:seed": "bash -c \"psql \"$SUPABASE_DB_URL\" -f supabase/seed.sql\"",
    "buckets:create": "bash scripts/create_buckets.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
